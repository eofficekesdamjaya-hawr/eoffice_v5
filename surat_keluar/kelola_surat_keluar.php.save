















<?php
require_once "../config/session.php";
require_once "../config/koneksi.php";

// 1. PROTEKSI AKSES
if (empty($_SESSION['id_user']) || $_SESSION['tipe_akses'] !== 'ruangan') {
    header("Location: ../auth/login.php");
    exit();
}

$id_user = (int) $_SESSION['id_user'];

// 2. QUERY MENGGUNAKAN ID_USER (Memastikan data terfilter dengan benar)
$query = "SELECT * FROM surat_keluar WHERE created_by = ? ORDER BY id_surat DESC";
$stmt = $conn->prepare($query);
$stmt->bind_param("i", $id_user);
$stmt->execute();
$all_data = $stmt->get_result();

// Memisahkan data berdasarkan tanggal di sisi PHP agar query lebih stabil
$hari_ini = [];
$riwayat = [];
$today = date('Y-m-d');

while ($row = $all_data->fetch_assoc()) {
    if ($row['tanggal_input'] == $today) {
        $hari_ini[] = $row;
    } else {
        $riwayat[] = $row;
    }
}

function renderBadgeStatusKeluar($status_raw) {
    $status = strtolower(trim($status_raw ?? 'pending'));
    switch ($status) {
        case 'pending': return "<span class='badge bg-warning text-dark'><i class='fas fa-clock me-1'></i> Pending</span>";
        case 'proses':  return "<span class='badge bg-primary text-white'><i class='fas fa-spinner me-1'></i> Proses</span>";
        case 'selesai': return "<span class='badge bg-success text-white'><i class='fas fa-check-double me-1'></i> Selesai</span>";
        default: return "<span class='badge bg-secondary'>".ucfirst($status)."</span>";
    }
}

function renderTableRows($data_array) {
    if (empty($data_array)) {
        echo "<tr><td colspan='13' class='text-center text-muted'>Tidak ada data ditemukan.</td></tr>";
        return;
    }
    $no = 1;
    foreach ($data_array as $row):
        // Trim untuk menghilangkan spasi tidak sengaja
        $nama_file = trim($row['file_surat'] ?? '');
        
        // Link yang benar untuk diakses browser
        // Asumsi: folder uploads sejajar dengan folder surat_keluar
        $path_link = "../uploads/surat_keluar/" . $nama_file;
    ?>
    <tr>
        <td class="text-center"><?= $no++ ?></td>
        <td><b><?= htmlspecialchars($row['no_agenda'] ?? '-') ?></b><br><small class="text-muted"><?= htmlspecialchars($row['asal_satuan'] ?? '-') ?></small></td>
        <td><?= htmlspecialchars($row['tanggal_input']) ?></td>
        <td><?= htmlspecialchars($row['no_surat'] ?? 'Diisi Setum') ?></td>
        <td><?= !empty($row['tanggal_surat']) ? htmlspecialchars($row['tanggal_surat']) : 'Diisi Setum' ?></td>
        <td><?= !empty($row['tanggal_kirim']) ? htmlspecialchars($row['tanggal_kirim']) : 'Diisi Setum' ?></td>
        <td><?= htmlspecialchars($row['bentuk_surat'] ?? '-') ?> / <?= htmlspecialchars($row['jenis_surat'] ?? '-') ?></td>
        <td><?= htmlspecialchars($row['klasifikasi_surat'] ?? '-') ?> / <?= htmlspecialchars($row['derajat_surat'] ?? '-') ?></td>
        <td><?= htmlspecialchars($row['tujuan_disposisi'] ?? '-') ?><br>-> <?= htmlspecialchars($row['tujuan_utama'] ?? '-') ?></td>
        <td><?= htmlspecialchars($row['perihal'] ?? '-') ?><br><small class="text-muted"><?= htmlspecialchars($row['tembusan'] ?? '-') ?></small></td>
        
        <td class="text-center">
            <?php if(!empty($nama_file)): ?>
                <a href="<?= htmlspecialchars($path_link) ?>" target="_blank" class="text-danger" title="<?= htmlspecialchars($nama_file) ?>">
                    <i class="fas fa-file-pdf fs-5"></i>
                </a>
            <?php else: ?> 
                <span class="text-muted">-</span>
            <?php endif; ?>
        </td>
        
        <td><?= renderBadgeStatusKeluar($row['status_pengiriman'] ?? '') ?></td>
        <td>
            <div class="btn-group">
                <a href="detail_surat_keluar.php?id=<?= $row['id_surat'] ?>" class="btn btn-sm btn-info text-white"><i class="fas fa-eye"></i></a>
                <a href="edit_surat_keluar.php?id=<?= $row['id_surat'] ?>" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
            </div>
        </td>
    </tr>
    <?php endforeach;
}

include '../layout/header.php';
?>

<div class="d-flex" id="wrapper">
    <?php include '../ruangan/sidebar.php'; ?>
    <div id="page-content-wrapper" class="w-100 bg-light">
        <div class="container-fluid py-4 px-4">
            <h4 class="fw-bold mb-4">Kelola Surat Keluar</h4>
            
            <div class="section-divider text-success fs-5 mb-2"><i class="fas fa-bell me-2"></i>Surat Hari Ini</div>
            <div class="card shadow-sm border-0 mb-5">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 1%;">No</th>
                                <th style="width: 10%;">No Agenda<br>Asal Satuan</th>
                                <th style="width: 8%;">Tgl Input</th>
                                <th style="width: 8%;">No Surat</th>
                                <th style="width: 8%;">Tgl Surat</th>
                                <th style="width: 8%;">Tgl Kirim</th>
                                <th style="width: 10%;">Bentuk / Jenis</th>
                                <th style="width: 10%;">Klas / Derajat</th>
                                <th style="width: 10%;">Tujuan Disposisi & Utama</th>
                                <th style="width: 10%;">Perihal & Tembusan</th>
                                <th style="width: 5%;">File</th>
                                <th style="width: 5%;">Status</th>
                                <th style="width: 7%;">Aksi</th>
                            </tr>
                        </thead>
                        <tbody><?php renderTableRows($hari_ini); ?></tbody>
                    </table>
                </div>
            </div>

            <div class="section-divider text-secondary fs-5 mb-2"><i class="fas fa-history me-2"></i>Riwayat Surat</div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>No</th><th>No Agenda/Asal</th><th>Tgl Input</th><th>No Surat</th><th>Tgl Surat</th>
                                <th>Tgl Kirim</th><th>Bentuk/Jenis</th><th>Klas/Derajat</th><th>Tujuan</th><th>Perihal</th>
                                <th>File</th><th>Status</th><th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody><?php renderTableRows($riwayat); ?></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
