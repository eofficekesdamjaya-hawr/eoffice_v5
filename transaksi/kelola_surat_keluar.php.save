                    </td>
                </tr>
            <?php 
                endwhile;
            else: 
            ?>
                <tr>
                    <td colspan="12" class="text-center py-4 text-muted bg-white">Belum ada rekaman log draf berkas surat keluar.</td>
                </tr>
            <?php endif; ?>
            </tbody>
        </table>
    </div>
</div>
<?php 
}
?>
</div> </div> </body>
</html>
</html>
