    14 => 'Kaur Infokes',
    15 => 'Kaur Log',
    16 => 'Juyar',
    17 => 'Persit',
    18 => 'Kaurpam',
    19 => 'Kaurdal',
    20 => 'Korpri',
    21 => 'Kaur Pers'

];

// Menangkap Parameter Filter Menu Sidebar Pimpinan
$filter = $_GET['filter'] ?? '';

$additional_query = "";

// Kondisi Logika Penyaringan Surat Komando
if ($filter === 'disposisi') {
    $additional_query = " AND (status_proses = 'Proses Disposisi' OR status_proses = 'Pending')";
} elseif ($filter === 'belum_ttd') {
    $additional_query = " AND status_proses = 'Di terima'";
} elseif ($filter === 'sudah_ttd') {
    $additional_query = " AND status_proses = 'Selesai'";
}

// PROTEKSI RUANGAN AKSES ABSOLUT: Batasi query hanya memunculkan milik ID user yang sedang login
if ($user_role === 'ruangan') {
    $safe_creator = mysqli_real_escape_string($conn, $id_user);
    
    // Memfilter data berdasarkan ID Angka pembuatnya (152) pada kolom created_by
    $additional_query .= " AND created_by = '$safe_creator'";
}

// Menangkap Parameter Filter Menu Sidebar Pimpinan
$filter = $_GET['filter'] ?? '';
$additional_query = "";

// Kondisi Logika Penyaringan Surat Komando (Diberikan prefix sk. agar aman saat JOIN)
if ($filter === 'disposisi') {
    $additional_query = " AND (sk.status_proses = 'Proses Disposisi' OR sk.status_proses = 'Pending')";
} elseif ($filter === 'belum_ttd') {
    $additional_query = " AND sk.status_proses = 'Di terima'";
} elseif ($filter === 'sudah_ttd') {
    $additional_query = " AND sk.status_proses = 'Selesai'";
}

// PROTEKSI RUANGAN AKSES ABSOLUT
if ($user_role === 'ruangan') {
    $safe_creator = mysqli_real_escape_string($conn, $id_user);
    $additional_query .= " AND sk.created_by = '$safe_creator'";
}

// =========================================================================
// 2. QUERY DATA SINKRON FIX TOTAL (Menggunakan u.id dan u.nama yang valid)
// =========================================================================

$sqlHariIni = "SELECT sk.*, u.nama AS nama_pembuat 
               FROM surat_keluar sk 
               LEFT JOIN users u ON sk.created_by = u.id 
               WHERE DATE(sk.created_at) = CURDATE() $additional_query ORDER BY sk.id_surat DESC";
$resHariIni = mysqli_query($conn, $sqlHariIni);

// Jika query hari ini gagal, coba jalankan alternatif kolom tanggal_input
if (!$resHariIni) {
    $sqlHariIni = "SELECT sk.*, u.nama AS nama_pembuat 
                   FROM surat_keluar sk 
                   LEFT JOIN users u ON sk.created_by = u.id 
                   WHERE DATE(sk.tanggal_input) = CURDATE() $additional_query ORDER BY sk.id_surat DESC";
    $resHariIni = mysqli_query($conn, $sqlHariIni);
}

$sqlSebelumnya = "SELECT sk.*, u.nama AS nama_pembuat 
                  FROM surat_keluar sk 
                  LEFT JOIN users u ON sk.created_by = u.id 
                  WHERE DATE(sk.created_at) < CURDATE() $additional_query ORDER BY sk.id_surat DESC";
$resSebelumnya = mysqli_query($conn, $sqlSebelumnya);

// Jika query sebelumnya gagal, coba jalankan alternatif kolom tanggal_input
if (!$resSebelumnya) {
    $sqlSebelumnya = "SELECT sk.*, u.nama AS nama_pembuat 
                      FROM surat_keluar sk 
                      LEFT JOIN users u ON sk.created_by = u.id 
                      WHERE DATE(sk.tanggal_input) < CURDATE() $additional_query ORDER BY sk.id_surat DESC";
    $resSebelumnya = mysqli_query($conn, $sqlSebelumnya);
}

function renderBadgeAlur($status) {
    $status_clean = trim(strtolower($status ?? ''));
    switch ($status_clean) {
        case 'pending': return "<span class='badge bg-warning text-dark'><i class='bi bi-clock'></i> Pending</span>";
        case 'di terima': 
        case 'diterima': return "<span class='badge bg-info text-white'><i class='bi bi-check-circle'></i> Di terima</span>";
        case 'ditolak': return "<span class='badge bg-danger text-white'><i class='bi bi-x-circle'></i> Ditolak</span>";
        case 'proses disposisi': return "<span class='badge bg-primary text-white'><i class='bi bi-shuffle'></i> Proses Disposisi</span>";
        case 'selesai': return "<span class='badge bg-success text-white'><i class='bi bi-check-all'></i> Selesai</span>";
        default: return "<span class='badge bg-secondary text-white'>".$status."</span>";
    }
}

