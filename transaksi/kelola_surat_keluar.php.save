
cdvdvzdvsdzvsdv<?php
if (session_status() === PHP_SESSION_NONE) {
    ini_set('session.cookie_lifetime', 43200); // Batas cookie di browser (12 Jam)
    ini_set('session.gc_maxlifetime', 43200);  // Batas penyimpanan session di server (12 Jam)
    ini_set('session.use_only_cookies', 1);
    ini_set('session.use_strict_mode', 1);
    session_start();
}
require_once "../config/koneksi.php";

// Validasi Utama: Harus login dan berstatus 'login'
if (empty($_SESSION['id_user']) || ($_SESSION['status'] ?? '') !== "login") {
    header("Location: ../auth/login_admin.php?pesan=akses_ditolak");
    exit();
}

// --- SINKRONISASI TOTAL BERDASARKAN HASIL INTIP SESSION ---
$id_user    = $_SESSION['id_user'] ?? ''; // Berisi Angka ID User (Contoh: 152)
$nama_user  = $_SESSION['nama_user'] ?? ($_SESSION['nama'] ?? 'Personel Ruangan'); // Berisi 'Dandenkeslap'
$tipe_akses = $_SESSION['tipe_akses'] ?? ''; // Berisi 'ruangan'

// Deteksi Role Jabatannya secara fleksibel
$user_role = ($tipe_akses === 'ruangan') ? 'ruangan' : 'admin';

// Array Pemetaan ID Ruangan Versi Sinkronisasi Nama Terbaru Anda
$ruanganMap = [
    1  => 'Pers Tuud', // Menyesuaikan urutan struktur database id_ruangan Anda
    2  => 'Seksi Was',
    3  => 'Seksi Dukkes', 
    4  => 'Seksi Kesprev', 
